<?xml version="1.0"?>
<launch>
<group ns="sim2">
<!-- general parameters definition starts-->

    <!-- obj detection model -->
    <!-- velodyne16 and velodyne64 work but 128 won't work  -->
    <arg name="obj_detect_path1" default="/home/zhaoliang/zzl/zhz03_github/Cooperfuse_framework/tracking_git_ws/src/multi_modalities_sensor_fusion/models/velodyne64/deploy.prototxt" />
    <arg name="obj_detect_path2" default="/home/zhaoliang/zzl/zhz03_github/Cooperfuse_framework/tracking_git_ws/src/multi_modalities_sensor_fusion/models/velodyne64/deploy.caffemodel" />
    <!-- <arg name="obj_detect_path1" default="/home/jiaqi/ros_ws/CooperFuse_Framework/tracking/src/multi_modalities_sensor_fusion/models/velodyne16/deploy.prototxt" />
    <arg name="obj_detect_path2" default="/home/jiaqi/ros_ws/CooperFuse_Framework/tracking/src/multi_modalities_sensor_fusion/models/velodyne16/deploy.caffemodel" /> -->
    
    <arg name="detection_object_topic" default="/detection/lidar_detector2/objects"/>
    <arg name="segment_cloud_topic" default="/segment2/clouds_segmented"/>

<!-- general parameters definition ends-->

    <!-- object detection -->
    <include file="$(find multi_modalities_sensor_fusion)/launch/launch2_muti_modalities_sensor_fusion.launch">        
          <arg name="network_definition_file" value="$(arg obj_detect_path1)" />
          <arg name="pretrained_model_file"  value="$(arg obj_detect_path2)"/>

          <!-- <arg name="points_src" default="/ouster_nw/points" /> -->
          <arg name="points_src" default="/ouster_nw/tchange/points" />

          <arg name="pub_detector_point_cluster" default="/detection/lidar_detector2/points_cluster" />
          <arg name="pub_detector_objects" default="/detection/lidar_detector2/objects" />
          <arg name="pub_points_cluster" default="/detection/lidar_detector2/points_cluster" />
          <arg name="pub_cluster_centroids" default="/detection/lidar_detector2/cluster_centroids" />
          <arg name="pub_cloud_clusters" default="/detection/lidar_detector2/cloud_clusters" />
          <arg name="pc_adjustable_z" default="0.9" />

    </include>

    <!-- Launch tracking_node -->
    <node name="tracking_node_pc_new_02" pkg="tracking_lib_execute" type="tracking_lib_execute_tracking_node_pc" output="screen">
        <rosparam command="load" file="$(find tracking_lib_execute)/config/new_tracking2_TRC_pc.yaml"/>
        <rosparam command="load" file="$(find tracking_lib_execute)/config/kitti/TrackingWorker_TRC.yaml"/>
    </node>

    <!-- tracking_lib autoware api -->
    <!--     <node pkg="api_tracking_lib_autoware" type="api_tracking_lib_autoware" name="api_tracking_lib_autoware" output="screen" /> -->
    <node pkg="api_tracking_lib_autoware" type="api_tracking_lib_autoware_sim" name="api_tracking_lib_autoware_02" output="screen">

        <param name="detection_object_topic" value="$(arg detection_object_topic)" />
        <param name="segment_cloud_topic" value="$(arg segment_cloud_topic)" />

    </node>

    <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz_rs" args="-d $(find data_project)/rviz/show_new.rviz" />

</group>

</launch>
