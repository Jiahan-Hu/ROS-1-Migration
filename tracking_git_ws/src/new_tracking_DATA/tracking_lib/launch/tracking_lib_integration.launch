<?xml version="1.0" encoding="utf-8"?>

<launch>
    <!-- Launch detection_node -->

<!--     <node name="detection_node" pkg="tracking_lib_execute" type="tracking_lib_execute_detection_node" output="screen">
        <remap from="/kitti/points_raw" to="/points_raw" />       
        <rosparam command="load" file="$(find tracking_lib_execute)/config/detection_TRC.yaml"/>
        <rosparam command="load" file="$(find tracking_lib_execute)/config/kitti/Segmenter_TRC.yaml"/>
    </node> -->

    
    <!-- !!!!!!the parameters for the transformation need to change !!!!! -->
    <!-- below is for september -->
<!--     <arg name="yaw_misalignment" default="-2.5" />
    <arg name="lever_x" default="0.1" />
    <arg name="lever_y" default="0" /> -->

    <!-- below is for november -->
    <arg name="yaw_misalignment" default="0.5" />
    <arg name="lever_x" default="1.65" />
    <arg name="lever_y" default="0" />

    <!-- This line needs to be changed for each different case with different vector maps -->
<!--     <arg name="vector_map_file" default="/home/jiaqi/catkin_ws_tracking_lib/carma_load/maps/12.21.2021.xodr.osm" /> -->

    <arg name="vector_map_file" default="/home/jiaqi/catkin_ws_tracking_lib/carma_load/maps/20211118_seg1.osm" />

<!--     <arg name="vector_map_file" default="/home/jiaqi/catkin_ws_tracking_lib/carma_load/maps/20211118_seg2.osm" /> -->

<!--     <arg name="vector_map_file" default="/home/jiaqi/catkin_ws_tracking_lib/carma_load/maps/20211118_seg3.osm" /> -->


    <!-- Launch tracking_node -->
    <node name="tracking_node" pkg="tracking_lib_execute" type="tracking_lib_execute_tracking_node" output="screen">
        <rosparam command="load" file="$(find tracking_lib_execute)/config/tracking_TRC.yaml"/>
        <rosparam command="load" file="$(find tracking_lib_execute)/config/kitti/TrackingWorker_TRC.yaml"/>
    </node>


    <!-- Launch rviz for visualization -->
    <node name="rviz" pkg="rviz" type="rviz" args="-d $(find tracking_lib)/rviz/demo_TRC.rviz"/>

    <!-- map loading -->
    <!-- vector map loader -->
    <node pkg="map_file" type="lanelet2_map_loader" name="lanelet2_map_loader"  args="$(arg vector_map_file)" output="screen">
        <remap from="/lanelet_map_bin" to="semantic_map"/>
    </node> 

    <!-- map param/tf loader -->
    <include file="$(find map_file)/launch/map_param_loader.launch">
        <arg name="file_name" value="$(arg vector_map_file)"/>
    </include>

        <!-- vector map visualization -->
    <node pkg="map_file" type="lanelet2_map_visualization" name="lanelet2_map_visualization" output="screen" >
        <remap from="/lanelet_map_bin" to="semantic_map"/>
    </node>

    <!-- tf publication -->
    <group>
        <remap from="georeference" to="map_param_loader/georeference"/>
        <include file="$(find tf_publisher)/launch/tf_publisher.launch">
            <arg name="yaw_misalignment_" value="$(arg yaw_misalignment)" />
            <arg name="lever_x_" value="$(arg lever_x)" />
            <arg name="lever_y_" value="$(arg lever_y)" />
        </include>
    </group>

    <node pkg="api_tracking_lib_autoware" type="api_tracking_lib_autoware" name="api_tracking_lib_autoware" output="screen" >

    </node>

     <node pkg="detected_objects_visualizer" type="visualize_detected_objects" name="ukf_track_visualization_01" output="screen" ns="/detection/object_tracker"/>


    <include file="$(find multi_modalities_sensor_fusion)/launch/muti_modalities_sensor_fusion.launch">        
          <arg name="network_definition_file" default="/home/jiaqi/autoware.ai/cnnseg/velodyne64/deploy.prototxt" />
          <arg name="pretrained_model_file"  default="/home/jiaqi/autoware.ai/cnnseg/velodyne64/deploy.caffemodel"/>
          <arg name="points_src" default="/points_raw" />
    </include>


</launch>
