Panels:
  - Class: rviz/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Coordinates1/Frames1
        - /KiTTI1
        - /Detection1
        - /Tracking1
      Splitter Ratio: 0.5
    Tree Height: 507
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.588679016
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: Objects
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Cell Size: 5
      Class: rviz/Grid
      Color: 160; 160; 164
      Enabled: true
      Line Style:
        Line Width: 0.0299999993
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 40
      Reference Frame: <Fixed Frame>
      Value: true
    - Class: rviz/TF
      Enabled: true
      Frame Timeout: 1000
      Frames:
        All Enabled: false
        cam00:
          Value: true
        cam01:
          Value: true
        cam02:
          Value: true
        cam03:
          Value: true
        imu:
          Value: true
        velodyne:
          Value: true
        world:
          Value: true
      Marker Scale: 15
      Name: Coordinates
      Show Arrows: true
      Show Axes: true
      Show Names: true
      Tree:
        world:
          imu:
            cam00:
              {}
            cam01:
              {}
            cam02:
              {}
            cam03:
              {}
            velodyne:
              {}
      Update Interval: 0
      Value: true
    - Class: rviz/Group
      Displays:
        - Class: rviz/Image
          Enabled: false
          Image Topic: /kitti/img_raw
          Max Value: 1
          Median window: 5
          Min Value: 0
          Name: KiTTI_Viewer
          Normalize Range: true
          Queue Size: 2
          Transport Hint: raw
          Unreliable: false
          Value: false
        - Alpha: 1
          Autocompute Intensity Bounds: true
          Autocompute Value Bounds:
            Max Value: 10
            Min Value: -10
            Value: true
          Axis: Z
          Channel Name: intensity
          Class: rviz/PointCloud2
          Color: 255; 255; 255
          Color Transformer: Intensity
          Decay Time: 0
          Enabled: false
          Invert Rainbow: false
          Max Color: 255; 255; 255
          Max Intensity: 0.99000001
          Min Color: 0; 0; 0
          Min Intensity: 0
          Name: KiTTI_Raw
          Position Transformer: XYZ
          Queue Size: 10
          Selectable: true
          Size (Pixels): 3
          Size (m): 0.00999999978
          Style: Points
          Topic: /kitti/points_raw
          Unreliable: false
          Use Fixed Frame: true
          Use rainbow: true
          Value: false
      Enabled: true
      Name: KiTTI
    - Class: rviz/Group
      Displays:
        - Class: rviz/MarkerArray
          Enabled: false
          Marker Topic: /tracking/segments_coarse
          Name: SegmentsCoarse
          Namespaces:
            {}
          Queue Size: 100
          Value: false
        - Class: rviz/MarkerArray
          Enabled: false
          Marker Topic: /tracking/segments_predict
          Name: SegmentsPredicted
          Namespaces:
            {}
          Queue Size: 100
          Value: false
        - Class: rviz/MarkerArray
          Enabled: true
          Marker Topic: /tracking/segments
          Name: SegmentsResult
          Namespaces:
            objects: true
          Queue Size: 100
          Value: true
      Enabled: true
      Name: Detection
    - Class: rviz/Group
      Displays:
        - Class: rviz/MarkerArray
          Enabled: true
          Marker Topic: /tracking/objects
          Name: Objects
          Namespaces:
            objects: true
          Queue Size: 100
          Value: true
        - Alpha: 1
          Autocompute Intensity Bounds: true
          Autocompute Value Bounds:
            Max Value: 10
            Min Value: -10
            Value: true
          Axis: Z
          Channel Name: intensity
          Class: rviz/PointCloud2
          Color: 255; 255; 255
          Color Transformer: Intensity
          Decay Time: 0
          Enabled: true
          Invert Rainbow: false
          Max Color: 255; 255; 255
          Max Intensity: 250.277786
          Min Color: 0; 0; 0
          Min Intensity: 0
          Name: Objects
          Position Transformer: XYZ
          Queue Size: 10
          Selectable: true
          Size (Pixels): 3
          Size (m): 0.00999999978
          Style: Points
          Topic: /tracking/clouds
          Unreliable: false
          Use Fixed Frame: true
          Use rainbow: true
          Value: true
        - Class: rviz/MarkerArray
          Enabled: true
          Marker Topic: /tracking/objects_vel
          Name: ObjectsVelText
          Namespaces:
            tracking_vels: true
          Queue Size: 100
          Value: true
        - Class: rviz/MarkerArray
          Enabled: true
          Marker Topic: /tracking/trajectory
          Name: ObjectsTrajectory
          Namespaces:
            tracking_trajectory: true
          Queue Size: 100
          Value: true
      Enabled: true
      Name: Tracking
    - Class: rviz/Image
      Enabled: false
      Image Topic: /cam00/image_raw
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: Image
      Normalize Range: true
      Queue Size: 2
      Transport Hint: raw
      Unreliable: false
      Value: false
    - Class: rviz/Camera
      Enabled: false
      Image Rendering: background and overlay
      Image Topic: /cam01/image_raw
      Name: Camera
      Overlay Alpha: 0.5
      Queue Size: 2
      Transport Hint: raw
      Unreliable: false
      Value: false
      Visibility:
        "": true
        Coordinates: true
        Detection:
          SegmentsCoarse: true
          SegmentsPredicted: true
          SegmentsResult: true
          Value: true
        Grid: true
        Image: true
        KiTTI:
          KiTTI_Raw: true
          KiTTI_Viewer: true
          Value: true
        Tracking:
          Objects: true
          ObjectsTrajectory: true
          ObjectsVelText: true
          Value: true
        Value: true
      Zoom Factor: 1
    - Class: rviz/Image
      Enabled: true
      Image Topic: /cam03/image_raw
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: Image
      Normalize Range: true
      Queue Size: 2
      Transport Hint: raw
      Unreliable: false
      Value: true
  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Default Light: true
    Fixed Frame: velodyne
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz/Interact
      Hide Inactive Objects: true
    - Class: rviz/MoveCamera
    - Class: rviz/Select
    - Class: rviz/FocusCamera
    - Class: rviz/Measure
    - Class: rviz/SetInitialPose
      Topic: /initialpose
    - Class: rviz/SetGoal
      Topic: /move_base_simple/goal
    - Class: rviz/PublishPoint
      Single click: true
      Topic: /clicked_point
  Value: true
  Views:
    Current:
      Class: rviz/Orbit
      Distance: 118.368248
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.0599999987
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Focal Point:
        X: -7.10749483
        Y: -0.219054222
        Z: -8.22644901
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.0500000007
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.00999999978
      Pitch: 1.3897965
      Target Frame: <Fixed Frame>
      Value: Orbit (rviz)
      Yaw: 3.0535779
    Saved: ~
Window Geometry:
  Camera:
    collapsed: false
  Displays:
    collapsed: false
  Height: 1056
  Hide Left Dock: false
  Hide Right Dock: true
  Image:
    collapsed: false
  KiTTI_Viewer:
    collapsed: false
  QMainWindow State: 
  Selection:
    collapsed: false
  Time:
    collapsed: false
  Tool Properties:
    collapsed: false
  Views:
    collapsed: true
  Width: 1855
  X: 65
  Y: 24
