<?xml version="1.0" ?>
<launch>
  <node name="bbx_pcl_sync_node" type="bbx_pcl_sync" pkg="synced_visualization" output="screen">
    <param name="input_topic_bbx" type="string" value="/tracking/objects_header_box_score" />
