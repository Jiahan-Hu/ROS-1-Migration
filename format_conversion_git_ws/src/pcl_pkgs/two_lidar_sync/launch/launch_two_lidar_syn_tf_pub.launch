    <arg name="input_topic1" default="/ouster/points_td" />
    <arg name="input_topic2" default="/rslidar_points" /> 
    <!--  <arg name="input_topic2" default="/new/rslidar_points" /> -->
    <arg name="output_topic1" default="/syn_pc_os" />
    <arg name="output_topic2" default="/syn_pc_new" />

    <arg name="transformed_lidar1_topic" default="/transformed_os" />
    <arg name="transformed_lidar2_topic" default="/transformed_new" />

    <node pkg="two_lidar_sync" type="two_lidar_syn_tf_pub" name="two_lidar_syn_tf_pub" output="screen" >
        <param name="input_topic1" value="$(arg input_topic1)" />
        <param name="input_topic2" value="$(arg input_topic2)" />
        <param name="transformed_lidar1_topic" value="$(arg transformed_lidar1_topic)" />
        <param name="transformed_lidar2_topic" value="$(arg transformed_lidar2_topic)" />
        <param name="output_topic1" value="$(arg output_topic1)" />
        <param name="output_topic2" value="$(arg output_topic2)" />
    </node>

    <arg name="rviz" default="true" />
    <group if="$(arg rviz)">
        <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz_sync" args="-d $(find transformation_pub)/rviz/rviz_show_2transformed_lidar.rviz" />
    </group>

