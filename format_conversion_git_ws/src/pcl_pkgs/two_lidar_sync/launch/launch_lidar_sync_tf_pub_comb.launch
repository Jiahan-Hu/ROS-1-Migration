    <arg name="transformed_lidar1_topic" default="/transformed_os" />
    <arg name="transformed_lidar2_topic" default="/transformed_new" />
    <arg name="comb_topic" default="/pcd_transformed_synched" />

    <node pkg="two_lidar_sync" type="two_lidar_syn_tf_comb_pub" name="two_lidar_syn_tf_comb_pub" output="screen" >
        <param name="input_topic1" value="$(arg input_topic1)" />
        <param name="input_topic2" value="$(arg input_topic2)" />
        <param name="transformed_lidar1_topic" value="$(arg transformed_lidar1_topic)" />
        <param name="transformed_lidar2_topic" value="$(arg transformed_lidar2_topic)" />
        <param name="output_topic1" value="$(arg output_topic1)" />
        <param name="output_topic2" value="$(arg output_topic2)" />
        <param name="comb_topic" value="$(arg comb_topic)" />
    </node>

    <arg name="rviz" default="true" />
    <group if="$(arg rviz)">
        <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz_sync" args="-d $(find ros_transform_utils)/rviz/rviz_show_comb_transformed_lidar.rviz" />
    </group>

