<?xml version='1.0'?>
<launch>
<param name="use_sim_time" value="true" />
<!-- <node pkg="tf" static_transform_publisher x y z yaw pitch roll frame_id child_frame_id period_in_ms> -->
  <node pkg="tf" type="static_transform_publisher" name="newrslidar_to_rslidar" args="3.8 -3.4 0.931 1.28163947893 0 0 rslidar newrslidar 100" />
  <!-- <node pkg="tf" type="static_transform_publisher" name="map_to_rslidar" args="0 0 0 0 0 0 map rslidar 10" />      -->

    <arg name="rviz" default="false" />
    <group if="$(arg rviz)">
        <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz_sync" args="-d $(find transformation_pub)/rviz/rviz_show_2transformed_lidar.rviz" />
    </group>

</launch>
