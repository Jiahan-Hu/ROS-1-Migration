<?xml version="1.0"?>
<launch>
<group ns="sim1">  

    <arg name="point_cloud_topic" default="/ouster_se/pc_subset" />
    <arg name="map_frame" default="map" />
    <arg name="child_frame" default="os_sensor_se" />
    <!-- <arg name="fix_x" default="29.252044126767487" />
    <arg name="fix_y" default="-157.99108715588525" />
    <arg name="fix_z" default="2.504110691351501" />
    <arg name="fix_heading" default="-0.04571448047729036" />
    <arg name="fix_pitch" default="-0.05262715935993412" />
    <arg name="fix_roll" default="-0.02814657310165272" /> -->
    <arg name="fix_x" default="62.22044126767487" />
    <arg name="fix_y" default="-176.99108715588525" />
    <arg name="fix_z" default="3.804110691351501" />
    <arg name="fix_heading" default="-32.04571448047729036" />
    <arg name="fix_pitch" default="-3.05262715935993412" />
    <arg name="fix_roll" default="1.2814657310165272" />

	<arg name="input_pc_topic" default="/ouster_se/points" />
    <arg name="output_pc_topic" default="/ouster_se/pc_subset" />

    <!-- tf publish for infra  -->
    <node pkg="tf_publisher" type="tf_publisher_simple" name="tf_publisher_simple_02" output="screen">
        <param name="point_cloud_topic" value="$(arg point_cloud_topic)" />
        <param name="map_frame" value="$(arg map_frame)" />
        <param name="child_frame" value="$(arg child_frame)" />
        <param name="fix_x" value="$(arg fix_x)" />
        <param name="fix_y" value="$(arg fix_y)" />
        <param name="fix_z" value="$(arg fix_z)" />
        <param name="fix_yaw" value="$(arg fix_heading)" />
        <param name="fix_pitch" value="$(arg fix_pitch)" />
        <param name="fix_roll" value="$(arg fix_roll)" />
    </node>


</group>

</launch>
