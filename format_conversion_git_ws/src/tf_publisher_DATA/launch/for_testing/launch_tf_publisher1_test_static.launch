<?xml version="1.0"?>
<launch>
<group ns="sim1">
    <!-- <arg name="point_cloud_topic" default="/syn_pc_rs" /> -->
    <!-- <arg name="point_cloud_topic" default="/detection/lidar_detector/points_cluster" /> -->
    <arg name="point_cloud_topic" default="/veh_1/rslidar_points" />
    <arg name="map_frame" default="map" />
    <arg name="child_frame" default="veh1_rslidar" />
    <arg name="fix_x" default="15.225689888" />
    <arg name="fix_y" default="-168.478668213" />
    <arg name="fix_z" default="0.646187543869" />
    <!-- <arg name="fix_heading" default="178.4175078236069" /> -->
    <arg name="fix_heading" default="4.5824921763930888" />
    <arg name="fix_pitch" default="-2.612260600082484" />
    <arg name="fix_roll" default="1.7717831757994458" />

    <node pkg="tf_publisher" type="tf_publisher_simple" name="tf_publisher_simple_01" output="screen">
        <param name="point_cloud_topic" value="$(arg point_cloud_topic)" />
        <param name="map_frame" value="$(arg map_frame)" />
        <param name="child_frame" value="$(arg child_frame)" />
        <param name="fix_x" value="$(arg fix_x)" />
        <param name="fix_y" value="$(arg fix_y)" />
        <param name="fix_z" value="$(arg fix_z)" />
        <param name="fix_yaw" value="$(arg fix_heading)" />
        <param name="fix_pitch" value="$(arg fix_pitch)" />
        <param name="fix_roll" value="$(arg fix_roll)" />
    </node>
</group>
</launch>
