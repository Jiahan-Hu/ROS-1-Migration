<!-- -->
<launch>

  <arg name="method_type" default="0" /> <!-- pcl_generic=0, pcl_anh=1, pcl_anh_gpu=2, pcl_openmp=3 -->
  <arg name="use_gnss" default="1" />
  <arg name="use_odom" default="false" />
  <arg name="use_imu" default="false" />
  <arg name="imu_upside_down" default="false" />
  <arg name="imu_topic" default="/imu_raw" />
  <arg name="queue_size" default="1" />
  <arg name="offset" default="linear" />
  <arg name="get_height" default="false" />
  <arg name="use_local_transform" default="false" />
  <arg name="sync" default="false" />
  <arg name="output_log_data" default="false" />
  <arg name="map_file" default="/home/mobility/ros_ws/Michelle_Wang_ws/localization_ros/v2v_5m.pcd" />

  
<node pkg="rviz" type="rviz" name="rviz" args="-d /home/mobility/ros_ws/Michelle_Wang_ws/localization_ros/rvizconfig1.rvizz"> </node>
<!--
<node pkg="lidar_localizer" type="localization_fusion" name="localization_fusion" output="screen"> </node>

<node pkg="lidar_localizer" type="localization_plot" name="localization_plot" output="screen"> </node>
-->
  <node pkg="lidar_localizer" type="ndt_matching_zzl" name="ndt_matching_zzl" output="screen">
    <param name="method_type" value="$(arg method_type)" />
    <param name="use_gnss" value="$(arg use_gnss)" />
    <param name="use_odom" value="$(arg use_odom)" />
    <param name="use_imu" value="$(arg use_imu)" />
    <param name="imu_upside_down" value="$(arg imu_upside_down)" />
    <param name="imu_topic" value="$(arg imu_topic)" />
    <param name="queue_size" value="$(arg queue_size)" />
    <param name="offset" value="$(arg offset)" />
    <param name="get_height" value="$(arg get_height)" />
    <param name="use_local_transform" value="$(arg use_local_transform)" />
    <param name="output_log_data" value="$(arg output_log_data)" />
    <param name="map_file" value="$(arg map_file)"/>
    <remap from="/points_raw" to="/sync_drivers/points_raw" if="$(arg sync)" />
    

    <param name="init_post_set_fromGNSS" value="0" />
    <param name="init_post_set_fromLAUNCH" value="0" />
    <param name="initial_pose_x" value="0.0" />
    <param name="initial_pose_y" value="0.0" />
    <param name="initial_pose_z" value="0.0" />
    <param name="initial_pose_roll" value="0.00" />
    <param name="initial_pose_pitch" value="0.00" />
    <param name="initial_pose_yaw" value="0.00" />

    <param name="map_ori_utm_easting" value="366601.25" />
    <param name="map_ori_utm_northing" value="3770693.3" />
    <param name="map_ori_utm_altitude" value="85.853022" />


  </node>
	


</launch>
