<?xml version="1.0"?>
<launch>
  <arg name="node_name" default="lidar_cam_info_sync_node"/>
  <arg name="pointcloud_topic" default="/veh_2/rslidar_points"/>
  <arg name="image_topic" default="/zed2i_v2/zed_node3/left/image_rect_color/compressed"/>
  <arg name="camera_info_topic" default="/zed2i_v2/zed_node3/left/camera_info"/>
  <arg name="pointcloud_output_topic" default="/veh_2/sync/rslidar_points"/>
  <arg name="image_output_topic" default="/zed2i_v2/zed_node3/left_update_sync/image_rect_color/compressed"/>
  <arg name="camera_info_output_topic" default="/zed2i_v2/zed_node3/left_update_sync/camera_info"/>

  <node pkg="lidar_camera_sync" type="lidar_cam_info_sync" name="$(arg node_name)" output="screen">
    <param name="pointcloud_topic" value="$(arg pointcloud_topic)"/>
    <param name="image_topic" value="$(arg image_topic)"/>
    <param name="camera_info_topic" value="$(arg camera_info_topic)"/>
    <param name="pointcloud_output_topic" value="$(arg pointcloud_output_topic)"/>
    <param name="image_output_topic" value="$(arg image_output_topic)"/>
    <param name="camera_info_output_topic" value="$(arg camera_info_output_topic)"/>
  </node>
</launch>

