<?xml version="1.0"?>
<launch>
    <arg name="pointcloud_topic" default="/veh_2/rslidar_points"/>
    <arg name="pointcloud_output_topic" default="/veh_2/sync/rslidar_points"/>
    <arg name="pointcloud_final_output_topic" default="/veh_2/sync_time/rslidar_points"/>

    <arg name="camera_info_topic" default="/zed2i_v2/zed_node3/left/camera_info"/>
    <arg name="camera_info_output_topic" default="/zed2i_v2/zed_node3/left_update_sync/camera_info"/>

    <arg name="image_topic" default="/zed2i_v2/zed_node3/left/image_rect_color/compressed"/>
    <arg name="image_output_topic" default="/zed2i_v2/zed_node3/left_update_sync/image_rect_color/compressed"/>
    <arg name="image_final_output_topic" default="/zed2i_v2/zed_node3/left_update_sync/image_rect_color"/>

    <include file="$(find lidar_camera_sync)/launch/launch_lidar_cam_info_sync.launch">
        <arg name="node_name" default="lidar_cam_info_sync_node"/>
        <arg name="pointcloud_topic" value="$(arg pointcloud_topic)" />
        <arg name="image_topic" value="$(arg image_topic)" />
        <arg name="camera_info_topic" value="$(arg camera_info_topic)" />
        <arg name="pointcloud_output_topic" value="$(arg pointcloud_output_topic)" />
        <arg name="image_output_topic" value="$(arg image_output_topic)" />
        <arg name="camera_info_output_topic" value="$(arg camera_info_output_topic)" /> 
    </include>

    <include file="$(find img_convert)/launch/launch_compress2image.launch">
        <arg name="compressed_topic" value="$(arg image_output_topic)" />
        <arg name="image_topic" value="$(arg image_final_output_topic)"/>
    </include>

    <include file="$(find pcl_time_change)/launch/launch_time_change.launch">
        <arg name="input_topic" value="$(arg pointcloud_output_topic)" />
        <arg name="output_topic" value="$(arg pointcloud_final_output_topic)" />
        <arg name="time_threshold" default="100000000" />      <!-- 100ms -->
    </include>

</launch>
