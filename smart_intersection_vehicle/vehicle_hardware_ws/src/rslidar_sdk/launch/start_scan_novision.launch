<launch>
  
  <node pkg="rslidar_laserscan" name="rslidar_laserscan_node2" type="rslidar_laserscan_node" output="screen">
    <param name="model" value="RSHELIOS"/>
    <param name="sub_topic" value="/new/rslidar_points" />
    <!-- the ring start from 1 -->
    <param name="ring" value="10" />  
  </node>

  <node pkg="rslidar_sdk" name="rslidar_sdk_node2" type="rslidar_sdk_node" output="screen">
    <param name="config_path" value=""/>
  </node>

  <!-- rviz -->
  <!-- <node pkg="rviz" name="rviz" type="rviz" args="-d $(find rslidar_sdk)/rviz/rviz.rviz" /> -->
  
</launch>
