<?xml version="1.0"?>
<launch>
  <!-- on the car -->
  <!-- <arg name="can_hardware_id" default="18706" /> -->
  <arg name="can_hardware_id" default="18706" />
  <arg name="can_circuit_id" default="0" />
  <arg name="can_bit_rate" default="500000" />
  <arg name="imu_topic" default="/gps/imu" />
  <arg name="inspvax_topic" default="/novatel/oem7/inspva" />
  <arg name="can_tx_topic" default="/can_tx"/>
  <arg name="can_rx_topic" default="/can_rx"/>

  <node pkg="kvaser_interface" type="kvaser_can_bridge" name="kvaser_can_bridge" output="screen">
    <param name="can_hardware_id" value="$(arg can_hardware_id)" />
    <param name="can_circuit_id" value="$(arg can_circuit_id)" />
    <param name="can_bit_rate" value="$(arg can_bit_rate)" />
    <param name="can_tx_topic" value="$(arg can_tx_topic)" />
    <param name="can_rx_topic" value="$(arg can_rx_topic)" />
  </node>

  <node pkg="kvaser_interface" type="ucla_can_parser" name="ucla_can_parser" output="screen">  
    <param name="can_tx_topic" value="$(arg can_tx_topic)" />
    <param name="can_rx_topic" value="$(arg can_rx_topic)" />
    <param name="imu_topic" value="$(arg imu_topic)" />
    <param name="inspvax_topic" value="$(arg inspvax_topic)" />
  </node>

</launch>
